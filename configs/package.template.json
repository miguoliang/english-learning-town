    "@testing-library/user-event": "^14.5.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.1",
    "jsdom": "^22.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",

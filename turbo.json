{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["CI"]
    },
    "test:unit": {
      "outputs": ["coverage/**"]
    },
    "test:integration": {
      "dependsOn": ["build", "^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build", "^build"],
      "outputs": ["test-results/**", "playwright-report/**"]
    },
    "test:coverage": {
      "dependsOn": ["test:unit"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "security-scan": {
      "outputs": ["security-report/**"]
    },
    "performance-test": {
      "dependsOn": ["build"],
      "outputs": ["performance-report/**"]
    },
    "accessibility-test": {
      "dependsOn": ["build"],
      "outputs": ["accessibility-report/**"]
    },
    "quality-check": {
      "dependsOn": ["test:coverage", "lint", "type-check", "security-scan"],
      "outputs": ["quality-report/**"]
    },
    "pre-commit": {
      "dependsOn": ["lint:fix", "type-check", "test:unit"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "release": {
      "dependsOn": ["quality-check", "test:e2e"],
      "outputs": []
    }
  }
}
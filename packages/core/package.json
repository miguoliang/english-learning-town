{
  "name": "@elt/core",
  "version": "1.0.0",
  "description": "Pure Entity Component System engine - reusable ECS implementation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "test": "vitest"
  },
  "keywords": [
    "ecs",
    "entity-component-system",
    "game-engine",
    "educational-games"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^5.0.5",
    "tsup": "^7.2.0",
    "typescript": "^5.2.2",
    "vitest": "^0.34.6"
  },
  "dependencies": {
    "mitt": "^3.0.1"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}